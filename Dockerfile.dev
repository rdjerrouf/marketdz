# ============================================================================
# MarketDZ – Dev Dockerfile (hot-reload with next dev)
# ============================================================================
FROM node:20-alpine

RUN apk add --no-cache libc6-compat
WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["npx", "next", "dev", "--turbopack"]
